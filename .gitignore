# --- C++ Build Artifacts ---
build/
bin/
lib/
*.o
*.so
*.dylib
*.exe
*.dll

# --- Python ---
__pycache__/
*.pyc
.ipynb_checkpoints/
*.egg-info/
.pytest_cache/
venv/

# --- Data Handling ---
# Ignore everything in data...
data/raw/*
data/processed/*

# ...EXCEPT the .gitkeep files (so folders show on GitHub)
!data/raw/.gitkeep
!data/processed/.gitkeep

# Keep sample data
!data/samples/

# --- System ---
.env
.DS_Store

# --- Claude Code ---
.claude/
